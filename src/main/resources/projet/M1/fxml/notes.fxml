<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="false"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="projet.M1.ui.NotesController">

    <VBox styleClass="page-container" spacing="24">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label fx:id="labelTitle"    text="Notes" styleClass="page-title"/>
                <Label fx:id="labelSubtitle" text=""      styleClass="page-subtitle"/>
            </VBox>
        </HBox>

        <!-- Sélecteurs — affichage conditionnel selon le rôle -->
        <!-- Professeur : Promotion + Module -->
        <HBox fx:id="selectorBarProf" spacing="12" alignment="CENTER_LEFT"
              visible="false" managed="false">
            <Label text="Promotion :" styleClass="form-label"/>
            <ComboBox fx:id="comboPromotion" prefWidth="220"/>
            <Label text="Module :" styleClass="form-label"/>
            <ComboBox fx:id="comboModuleProf" prefWidth="220"/>
        </HBox>

        <!-- Étudiant : Module uniquement -->
        <HBox fx:id="selectorBarEtu" spacing="12" alignment="CENTER_LEFT"
              visible="false" managed="false">
            <Label text="Module :" styleClass="form-label"/>
            <ComboBox fx:id="comboModuleEtu" prefWidth="280"/>
        </HBox>

        <!-- Spinner de chargement -->
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="32" prefHeight="32"
                           visible="true" managed="true"/>

        <!-- Contenu dynamique -->
        <VBox fx:id="notesContainer" spacing="12"/>

    </VBox>

</ScrollPane>
