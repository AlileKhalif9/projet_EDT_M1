<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Page "Demandes de modification" — une seule page, deux vues selon le rôle :

    PROFESSEUR (US6 à US9) :
      Bouton "+ Nouvelle demande" qui ouvre un formulaire en 3 étapes :
        1. Salle souhaitée (liste déroulante des salles disponibles)
        2. Créneau à modifier + nouveau créneau souhaité
        3. Raison (liste pré-remplie)
      En bas : historique des demandes du prof (rempli par le back-end)

    GESTIONNAIRE (US10 à US12) :
      Directement la liste de toutes les demandes en attente,
      avec boutons "Approuver" et "Rejeter" sur chacune.
      Pas de bouton "Nouvelle demande".
-->
<ScrollPane fitToWidth="true" fitToHeight="false"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="projet.M1.ui.ModificationRequestController">

    <VBox styleClass="page-container" spacing="24">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label fx:id="labelTitle"    text="Mes demandes"    styleClass="page-title"/>
                <Label fx:id="labelSubtitle" text="Demandez des changements à votre emploi du temps"
                       styleClass="page-subtitle"/>
            </VBox>
            <!-- Visible uniquement pour le prof -->
            <Button fx:id="btnNouvellesDemande"
                    text="+ Nouvelle demande"
                    styleClass="btn-primary"
                    onAction="#onToggleForm"/>
        </HBox>

        <!-- ================================================================
             FORMULAIRE PROF (US6–9) — masqué par défaut
        ================================================================ -->
        <VBox fx:id="formPanel" visible="false" managed="false"
              styleClass="mod-form-card" spacing="24">

            <VBox spacing="4">
                <Label text="Nouvelle demande de modification" styleClass="mod-form-title"/>
                <Label text="Tout est en liste déroulante — rien à saisir manuellement"
                       styleClass="mod-form-desc"/>
            </VBox>

            <Separator/>

            <!-- Étape 1 : Quelle date et quelle salle ? (US6) -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 1 — Quelle date et quelle salle ?" styleClass="form-step-title"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Date souhaitée" styleClass="form-label"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Salle souhaitée" styleClass="form-label"/>
                        <ComboBox fx:id="comboSalle"
                                  promptText="Choisir une salle disponible..."
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- Étape 2 : Quel créneau changer ? (US7) -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 2 — Quel créneau souhaitez-vous modifier ?" styleClass="form-step-title"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Créneau actuel à modifier" styleClass="form-label"/>
                        <ComboBox fx:id="comboCreneauActuel"
                                  promptText="Ex : Lundi 8h00 – 10h00"
                                  maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Nouveau créneau souhaité" styleClass="form-label"/>
                        <ComboBox fx:id="comboNouveauCreneau"
                                  promptText="Choisir un créneau libre..."
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- Étape 3 : Raison (US8) -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 3 — Raison de la modification" styleClass="form-step-title"/>
                <ComboBox fx:id="comboRaison"
                          promptText="Sélectionner une raison..."
                          maxWidth="Infinity"/>
            </VBox>

            <Separator/>

            <!-- Boutons US8 / US9 -->
            <HBox spacing="12">
                <Button text="Soumettre la demande" styleClass="btn-primary"  onAction="#onSubmit"/>
                <Button text="Annuler"              styleClass="btn-secondary" onAction="#onAnnulerForm"/>
            </HBox>

        </VBox>

        <!-- ================================================================
             LISTE DES DEMANDES (remplie dynamiquement par le controller)
             Prof → ses demandes passées
             Gestionnaire → toutes les demandes en attente avec Approuver/Rejeter
        ================================================================ -->
        <VBox fx:id="requestsContainer" spacing="16"/>

    </VBox>

</ScrollPane>
