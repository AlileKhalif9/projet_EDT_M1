<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Page "Demandes de modification"

    PROFESSEUR (US6–9) :
      Étape 1 — Identifier le cours : date + heure → label indique le cours trouvé ou une erreur
      Étape 2 — Nouveau créneau : date + heure début + heure fin + salle (optionnel)
      Étape 3 — Raison

    GESTIONNAIRE (US10–12) :
      Liste des demandes PENDING avec Approuver / Rejeter.
-->
<ScrollPane fitToWidth="true" fitToHeight="false"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="projet.M1.ui.ModificationRequestUI">

    <VBox styleClass="page-container" spacing="24">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label fx:id="labelTitle"    text="Mes demandes"    styleClass="page-title"/>
                <Label fx:id="labelSubtitle" text="Demandez des changements à votre emploi du temps"
                       styleClass="page-subtitle"/>
            </VBox>
            <Button fx:id="btnNouvellesDemande"
                    text="+ Nouvelle demande"
                    styleClass="btn-primary"
                    onAction="#onToggleForm"/>
        </HBox>

        <!-- ================================================================
             FORMULAIRE PROF (US6–9) — masqué par défaut
        ================================================================ -->
        <VBox fx:id="formPanel" visible="false" managed="false"
              styleClass="mod-form-card" spacing="24">

            <VBox spacing="4">
                <Label text="Nouvelle demande de modification" styleClass="mod-form-title"/>
                <Label text="Indiquez quel cours déplacer, vers quel créneau, et pourquoi"
                       styleClass="mod-form-desc"/>
            </VBox>

            <Separator/>

            <!-- ── Étape 1 : Identifier le cours à modifier ── -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 1 — Quel cours souhaitez-vous modifier ?" styleClass="form-step-title"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Date du cours" styleClass="form-label"/>
                        <DatePicker fx:id="datePickerActuel" maxWidth="Infinity"
                                    promptText="Sélectionnez une date"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Heure de début du cours" styleClass="form-label"/>
                        <ComboBox fx:id="comboHeureActuelle"
                                  promptText="Ex : 08:00"
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <!-- Résultat de la recherche -->
                <Label fx:id="labelCoursFound"
                       styleClass="cours-found-idle"
                       text="Choisissez une date et une heure pour identifier le cours"
                       wrapText="true"/>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- ── Étape 2 : Nouveau créneau souhaité ── -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 2 — Nouveau créneau souhaité" styleClass="form-step-title"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Nouvelle date" styleClass="form-label"/>
                        <DatePicker fx:id="datePickerNouveau" maxWidth="Infinity"
                                    promptText="Sélectionnez une date"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Heure de début" styleClass="form-label"/>
                        <ComboBox fx:id="comboHeureDebutNouveau"
                                  promptText="Ex : 14:00"
                                  maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Heure de fin" styleClass="form-label"/>
                        <ComboBox fx:id="comboHeureFinNouveau"
                                  promptText="Ex : 16:00"
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Salle souhaitée  (optionnel)" styleClass="form-label"/>
                    <ComboBox fx:id="comboSalle"
                              promptText="Laisser vide pour garder la même salle"
                              maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- ── Étape 3 : Raison ── -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 3 — Raison de la modification" styleClass="form-step-title"/>
                <ComboBox fx:id="comboRaison"
                          promptText="Sélectionner une raison..."
                          maxWidth="Infinity"/>
            </VBox>

            <Separator/>

            <HBox spacing="12">
                <Button text="Soumettre la demande" styleClass="btn-primary"  onAction="#onSubmit"/>
                <Button text="Annuler"              styleClass="btn-secondary" onAction="#onAnnulerForm"/>
            </HBox>

        </VBox>

        <!-- ================================================================
             LISTE DES DEMANDES (remplie dynamiquement)
             Prof        → historique de ses demandes
             Gestionnaire → demandes PENDING avec Approuver / Rejeter
        ================================================================ -->
        <VBox fx:id="requestsContainer" spacing="16"/>

    </VBox>

</ScrollPane>
