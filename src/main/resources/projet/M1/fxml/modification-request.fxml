<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="false"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC; -fx-border-color: transparent;"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="projet.M1.ui.ModificationRequestController">

    <VBox styleClass="page-container" spacing="24">

        <!-- ================================================================
             En-tête
        ================================================================ -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label fx:id="labelTitle"    text="Mes demandes"    styleClass="page-title"/>
                <Label fx:id="labelSubtitle" text="Demandez des changements à votre emploi du temps"
                       styleClass="page-subtitle"/>
            </VBox>
            <Button fx:id="btnNouvellesDemande"
                    text="+ Nouvelle demande"
                    styleClass="btn-primary"
                    onAction="#onToggleForm"/>
        </HBox>

        <!-- ================================================================
             Formulaire (masqué par défaut)
        ================================================================ -->
        <VBox fx:id="formPanel" visible="false" managed="false"
              styleClass="mod-form-card" spacing="24">

            <VBox spacing="4">
                <Label text="Demander une modification de cours" styleClass="mod-form-title"/>
                <Label text="Remplissez les étapes ci-dessous pour soumettre votre demande"
                       styleClass="mod-form-desc"/>
            </VBox>

            <Separator/>

            <!-- Étape 1 : Quelle date ? -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 1 — Quelle date ?" styleClass="form-step-title"/>
                <VBox spacing="6">
                    <Label text="Date souhaitée" styleClass="form-label"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- Étape 2 : Quel horaire changer ? -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 2 — Quel horaire souhaitez-vous modifier ?" styleClass="form-step-title"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Créneau à modifier" styleClass="form-label"/>
                        <ComboBox fx:id="comboCreneauActuel"
                                  promptText="Ex : 9h00 – 11h00"
                                  maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Salle actuelle" styleClass="form-label"/>
                        <ComboBox fx:id="comboSalleActuelle"
                                  promptText="Salle concernée..."
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator styleClass="form-separator"/>

            <!-- Étape 3 : Par quoi remplacer ? -->
            <VBox spacing="12" styleClass="form-step">
                <Label text="Étape 3 — Par quoi souhaitez-vous le remplacer ?" styleClass="form-step-title"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Nouvel horaire souhaité" styleClass="form-label"/>
                        <ComboBox fx:id="comboNouvelHoraire"
                                  promptText="Choisir un créneau..."
                                  maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Nouvelle salle (optionnel)" styleClass="form-label"/>
                        <ComboBox fx:id="comboNouvelleSalle"
                                  promptText="Garder la même ou en choisir une..."
                                  maxWidth="Infinity"/>
                    </VBox>
                </HBox>
                <VBox spacing="6">
                    <Label text="Raison de la modification" styleClass="form-label"/>
                    <ComboBox fx:id="comboRaison"
                              promptText="Sélectionner une raison..."
                              maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Separator/>

            <!-- Boutons -->
            <HBox spacing="12">
                <Button text="Soumettre la demande"
                        styleClass="btn-primary"
                        onAction="#onSubmit"/>
                <Button text="Annuler"
                        styleClass="btn-secondary"
                        onAction="#onAnnulerForm"/>
            </HBox>

        </VBox>

        <!-- ================================================================
             Liste des demandes (remplie par le back-end plus tard)
        ================================================================ -->
        <VBox fx:id="requestsContainer" spacing="16"/>

    </VBox>

</ScrollPane>
