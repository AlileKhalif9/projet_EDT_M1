<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="projet.M1.ui.RoomSelectionController"
      styleClass="room-selection-container"
      spacing="20">

    <!-- ============================================================
         En-tête
    ============================================================ -->
    <VBox spacing="4">
        <Label text="Sélectionner une salle" styleClass="page-title"/>
        <Label text="Choisissez la salle pour votre demande de modification de cours"
               styleClass="page-subtitle"/>
    </VBox>

    <!-- ============================================================
         Barre de recherche
    ============================================================ -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par nom ou équipement…"
                   styleClass="search-field"/>
    </HBox>

    <!-- ============================================================
         Grille de salles (remplie dynamiquement)
    ============================================================ -->
    <ScrollPane fitToWidth="true" fitToHeight="false" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="roomGrid"
                  styleClass="room-grid"
                  hgap="16" vgap="16"/>
    </ScrollPane>

    <!-- ============================================================
         Barre de confirmation (bas de page)
    ============================================================ -->
    <HBox styleClass="selection-bar" spacing="16" alignment="CENTER_LEFT">
        <Label fx:id="labelSelected"
               text="Aucune salle sélectionnée"
               styleClass="selection-info"
               HBox.hgrow="ALWAYS"/>
        <Button text="Annuler"
                styleClass="btn-secondary"
                onAction="#onCancel"/>
        <Button fx:id="btnConfirm"
                text="Confirmer la salle →"
                styleClass="btn-primary"
                onAction="#onConfirm"
                disable="true"/>
    </HBox>

</VBox>
