<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="timetablePU">

        <!-- Toutes les entités BDD -->
        <class>projet.M1.BDD.entity.UserEntity</class>
        <class>projet.M1.BDD.entity.PromotionEntity</class>
        <class>projet.M1.BDD.entity.GroupeEtudiantEntity</class>
        <class>projet.M1.BDD.entity.ModuleEntity</class>
        <class>projet.M1.BDD.entity.NoteEntity</class>
        <class>projet.M1.BDD.entity.CoursEntity</class>
        <class>projet.M1.BDD.entity.HoraireEntity</class>
        <class>projet.M1.BDD.entity.SalleEntity</class>
        <class>projet.M1.BDD.entity.CoursModificationRequestEntity</class>

        <properties>
            <!-- PostgreSQL -->
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://localhost:5432/timetable"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="password"/>
            <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>

            <property name="hibernate.dialect"       value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto"  value="update"/>
            <property name="hibernate.show_sql"      value="true"/>
        </properties>

    </persistence-unit>
</persistence>